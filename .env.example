# ─────────────────────────────────────────────────────────────
# Example environment file. Copy to `.env` and fill in real values.
# NEVER commit the real `.env` — it is gitignored.
# These are only needed if/when you run the optional Node API in /server.
# The static site in /public needs NONE of these.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (local dev example)
DATABASE_URL=postgresql://user:password@localhost:5432/success_toolkits

# Secret used to sign auth tokens. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
